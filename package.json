{
  "name": "optmax",
  "version": "1.2.1",
  "description": "Cash-Secured Puts Tracker",
  "main": "main.js",
  "desktopName": "OptMax.desktop",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "node test/strategies.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "yahoo-finance2": "^3.15.3"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.61.0"
  },
  "build": {
    "appId": "com.optmax.app",
    "productName": "OptMax",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "juliantoledo",
        "repo": "optmax"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "icon": "assets/icon.png",
      "identity": null,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "OptMax ${version}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Office",
      "synopsis": "Cash-Secured Puts Tracker",
      "syncDesktopName": true
    }
  }
}
